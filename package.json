    "@types/uglify-js": "latest",
    "eslint": "latest",
    "eslint-plugin-jsdoc": "latest",
    "mitata": "latest",
    "terser": "^5.39.0",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  },
  "dependencies": {
    "@mapl/framework": "^0.0.26",
    "@mapl/router": "^0.4.13",
    "safe-throw": "^0.0.9"
  }
}
